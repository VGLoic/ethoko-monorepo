{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["./hardhat.config.ts", "./e2e-test/**/*", "./deploy/**/*"],
  "exclude": [
    "./node_modules",
    "./dist",
    "./artifacts",
    "./cache",
    "./lib",
    "./.ethoko",
    "./.ethoko-typings"
  ]
}
