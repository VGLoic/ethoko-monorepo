/* Based on https://github.com/tsconfig/bases/blob/501da2bcd640cf95c95805783e1012b992338f28/bases/node22.json */
{
  "compilerOptions": {
    "lib": ["es2023"],
    "module": "NodeNext",
    "target": "es2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "nodenext",
    "outDir": "dist",
    "types": ["node"],
    "resolveJsonModule": true
  },
  "include": [
    "./hardhat.config.ts",
    "./e2e-test/**/*",
    "./ignition/modules",
    "./scripts/*"
  ],
  "exclude": [
    "./node_modules",
    "./dist",
    "./artifacts",
    "./cache",
    "./lib",
    "./ethoko-storage",
    "./.ethoko",
    "./.ethoko-typings"
  ]
}
