{
  "name": "foundry_etherscan-verification",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "ethoko": "node ../../packages/cli/dist/index.js",
    "lint": "hardhat ethoko typings && eslint . --max-warnings 0",
    "check-format": "forge fmt --check",
    "format-contracts": "forge fmt",
    "format": "forge fmt",
    "hardhat": "hardhat",
    "compile": "forge build --skip test --skip script --force --use-literal-content",
    "check-types": "hardhat ethoko typings && tsc --noEmit",
    "test:e2e:apps": "vitest run e2e-test",
    "reset-example": "./ethoko-scripts/reset-example.sh",
    "verify-2026-02-02": "tsx ./scripts/verify-2026-02-02.ts"
  },
  "devDependencies": {
    "@ethoko/cli": "workspace:*",
    "@ethoko/eslint-config": "workspace:*",
    "@nomicfoundation/hardhat-ignition": "^3.0.7",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.2",
    "@nomicfoundation/hardhat-verify": "^3.0.0",
    "@types/node": "^22.8.5",
    "dotenv": "^17.2.4",
    "eslint": "^9.39.1",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.1.7",
    "hardhat-ethoko": "workspace:*",
    "tsx": "^4.21.0",
    "typescript": "~5.8.0",
    "viem": "^2.43.0",
    "vitest": "^4.0.17"
  }
}
