{
  "extends": "@ethoko/typescript-config/node-base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "bun"],
    "baseUrl": ".",
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"],
      "@test/*": ["./test/*"]
    }
  },
  "exclude": ["./dist", "./node_modules"],
  "include": ["src", "test", "scripts", "templates-builder"]
}
