{
  "name": "@ethoko/cli-beacon",
  "version": "0.6.0",
  "private": false,
  "description": "Standalone CLI for Ethoko artifact management.",
  "author": "Loïc Vincent-Genod",
  "homepage": "https://github.com/VGLoic/ethoko",
  "bugs": {
    "url": "https://github.com/VGLoic/ethoko/issues"
  },
  "keywords": [
    "web3",
    "ethereum",
    "smart contracts",
    "foundry",
    "hardhat",
    "cli",
    "infrastructure"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "ethoko": "./dist/index.js"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "generate-template": "mkdir -p templates && cp templates-builder/typings.ts templates/typings.txt",
    "build": "pnpm generate-template && tsup",
    "build:binary": "pnpm generate-template &&  bun scripts/build-binary.ts",
    "publish-cli": "bun scripts/publish-cli.ts",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write src/**/*.ts test/**/*.ts scripts/**/*.ts templates-builder/**/*.ts",
    "check-format": "prettier --check src/**/*.ts test/**/*.ts scripts/**/*.ts templates-builder/**/*.ts",
    "check-types": "tsc --noEmit && vitest run --project typecheck",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:localstack:up": "docker compose -f compose.test.yml up -d",
    "test:localstack:down": "docker compose -f compose.test.yml down -v",
    "test:localstack:logs": "docker compose -f compose.test.yml logs -f"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.624.0",
    "@aws-sdk/client-sts": "^3.624.0",
    "@clack/prompts": "^1.1.0",
    "@ethersproject/keccak256": "^5.7.0",
    "@ethersproject/strings": "^5.7.0",
    "@smithy/types": "^3.3.0",
    "commander": "^12.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ethoko/eslint-config": "workspace:*",
    "@ethoko/typescript-config": "workspace:*",
    "@types/bun": "^1.2.22",
    "@types/node": "^22.1.0",
    "bun": "^1.2.22",
    "eslint": "^9.39.1",
    "tsup": "^8.2.4",
    "typescript": "5.9.2",
    "vitest": "^4.0.17"
  }
}
