{
  "name": "ethoko",
  "description": "Monorepo for Ethoko packages and applications, warehouse for smart contract compilation artifacts.",
  "author": "Loïc Vincent-Genod",
  "homepage": "https://github.com/VGLoic/ethoko",
  "bugs": {
    "url": "https://github.com/VGLoic/ethoko/issues"
  },
  "private": true,
  "keywords": [
    "web3",
    "ethereum",
    "smart contracts",
    "hardhat",
    "foundry",
    "plugin",
    "infrastructure"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test:unit": "turbo run test:unit",
    "test:e2e:core": "pnpm --filter @ethoko/cli-beacon test:e2e",
    "test:e2e:apps": "turbo run test:e2e:apps",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint:ci",
    "format": "turbo run format",
    "check-format": "turbo run check-format",
    "check-types": "turbo run check-types",
    "check-types:ci": "turbo run check-types:ci",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "prettier": "^3.7.4",
    "turbo": "^2.8.0",
    "typescript": "5.9.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bun"
    ]
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20"
  }
}
